# Runtime
APP_NAME=Baudoku API
ENVIRONMENT=local
PORT=8000
ALLOWED_ORIGINS=*

# Supabase backend-only credentials. Never copy the service role key to Expo.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AI provider settings. For the MVP only OpenAI is implemented in code.
AI_ENABLED=true
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_TEXT_MODEL=gpt-5.5
OPENAI_VISION_MODEL=gpt-5.5
AI_REQUEST_TIMEOUT_SECONDS=60
AI_MAX_RETRIES=2
AI_PROMPT_VERSION=bba-ki-v1
AI_RATE_LIMIT_PER_USER_PER_MINUTE=20

# Prepared for a later provider switch; not active while AI_PROVIDER=openai.
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
